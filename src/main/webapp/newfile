<div class="col-3">

            <h:form>

                <!-- UPDATE ORDER STATUS -->
                <p:card title="Update Order Status" styleClass="mb-4">

                    <p:selectOneMenu value="#{orderBean.selectedOrder.orderStatus}" style="width:100%">
                        <f:selectItem itemLabel="Pending" itemValue="Pending"/>
                        <f:selectItem itemLabel="Processing" itemValue="Processing"/>
                        <f:selectItem itemLabel="Shipped" itemValue="Shipped"/>
                        <f:selectItem itemLabel="Completed" itemValue="Completed"/>
                    </p:selectOneMenu>

                    <p:commandButton value="Update"
                                     icon="pi pi-check"
                                     action="#{orderBean.updateOrderStatus}"
                                     class="w-full mt-3"/>
                </p:card>



                <!-- UPDATE PAYMENT STATUS -->
                <p:card title="Update Payment Status">

                    <p:selectOneMenu value="#{orderBean.selectedOrder.paymentStatus}" style="width:100%">
                        <f:selectItem itemLabel="Pending" itemValue="Pending"/>
                        <f:selectItem itemLabel="Paid" itemValue="Paid"/>
                        <f:selectItem itemLabel="Failed" itemValue="Failed"/>
                    </p:selectOneMenu>

                    <p:commandButton value="Update"
                                     icon="pi pi-check"
                                     action="#{orderBean.updatePaymentStatus}"
                                     class="w-full mt-3"/>
                </p:card>

            </h:form>

        </div>